# 编译镜像 - 用于在 Docker 中编译 tryunzip
FROM golang:1.25-alpine

# 设置Go工具链为auto，自动下载合适版本
ENV GOTOOLCHAIN=auto

# 安装编译所需的工具
RUN apk add --no-cache \
    git \
    upx \
    musl-dev \
    gcc \
    zip \
    tar \
    bash

# 设置工作目录
WORKDIR /build

# 复制依赖文件并下载
COPY go.mod go.sum ./
RUN go mod download

# 复制源代码
COPY . .
